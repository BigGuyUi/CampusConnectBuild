@using Microsoft.AspNetCore.Components

<div class="event-card">
    <article class="card event-card-inner h-100">
        <div class="event-thumb" style="@GetThumbStyle()">
            <div class="thumb-text">@GetInitials()</div>
        </div>

        <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <h3 class="card-title h6 mb-0 event-title" title="@Title">@Title</h3>
                <time class="event-date small text-muted">@Date</time>
            </div>

            @if (!string.IsNullOrWhiteSpace(SocietyName))
            {
                <div class="mb-2">
                    <span class="badge event-society">@SocietyName</span>
                </div>
            }

            @if (ChildContent is not null)
            {
                <div class="mb-3 event-extra">
                    @ChildContent
                </div>
            }

            <div class="mt-auto d-flex justify-content-between align-items-center">
                <NavLink class="btn btn-sm btn-outline-dark" href="@GetEventHref()">View</NavLink>
                <div class="event-actions text-muted small">Details ?</div>
            </div>
        </div>
    </article>
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter, EditorRequired] public string Date { get; set; } = "";
    [Parameter] public string SocietyName { get; set; } = "";
    [Parameter] public int EventId { get; set; }
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }

    string GetEventHref()
    {
        var slug = GetSlug();
        return !string.IsNullOrWhiteSpace(slug) ? $"/Events/{slug}" : $"/Events/{EventId}";
    }

    string GetSlug()
    {
        if (!string.IsNullOrWhiteSpace(Slug))
            return Slug;

        // fallback: generate a simple URL-safe slug from the title
        return Slugify(Title);
    }

    // Simple slugify: lower-case, replace spaces with '-', remove invalid chars, collapse multiple '-'
    string Slugify(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return "";

        input = input.Trim().ToLowerInvariant();

        var sb = new System.Text.StringBuilder(input.Length);
        bool lastWasDash = false;
        foreach (var ch in input)
        {
            if ((ch >= 'a' && ch <= 'z') || (ch >= '0' && ch <= '9'))
            {
                sb.Append(ch);
                lastWasDash = false;
            }
            else if (ch == ' ' || ch == '-' || ch == '_' )
            {
                if (!lastWasDash)
                {
                    sb.Append('-');
                    lastWasDash = true;
                }
            }
            // ignore punctuation and other chars
        }

        var slug = sb.ToString().Trim('-');
        // collapse multiple dashes (defensive)
        while (slug.Contains("--")) slug = slug.Replace("--", "-");
        return slug;
    }

    // Simple initials used in thumb
    string GetInitials()
    {
        if (string.IsNullOrWhiteSpace(Title)) return "?";
        var parts = Title.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }

    // Generate a consistent accent gradient per EventId (falls back to a neutral gradient)
    string GetThumbStyle()
    {
        var colors = new[] {
            "linear-gradient(135deg,#ef4444 0%,#fb923c 100%)",
            "linear-gradient(135deg,#8b5cf6 0%,#06b6d4 100%)",
            "linear-gradient(135deg,#06b6d4 0%,#10b981 100%)",
            "linear-gradient(135deg,#f59e0b 0%,#ef4444 100%)"
        };
        var idx = EventId > 0 ? Math.Abs(EventId.GetHashCode()) % colors.Length : 0;
        return $"background:{colors[idx]};min-height:72px;display:flex;align-items:center;justify-content:center;";
    }
}