@page "/Events/Create"
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using CampusConnect.Models
@using CampusConnect.Services
@inject ISocietyService SocietyService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Create Event — Pick Society</PageTitle>

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><NavLink href="/Events">Events</NavLink></li>
            <li class="breadcrumb-item active" aria-current="page">Create event</li>
        </ol>
    </nav>

    <header class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h4 mb-1">Create an event</h1>
            <div class="text-muted small">Select which society the event will belong to.</div>
        </div>
        <div>
            <NavLink class="btn btn-outline-secondary btn-sm" href="/Events">Back to events</NavLink>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="text-center py-5 text-muted">
            <div class="spinner-border" role="status" aria-hidden="true"></div>
            <div class="mt-2">Loading societies…</div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (!UserSocieties.Any())
    {
        <div class="alert alert-info">You are not a member of any societies. Join one before creating events.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var s in UserSocieties)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <article class="card society-card h-100">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex align-items-start mb-3">
                                <div class="society-initials me-3">@GetInitials(s.Name)</div>
                                <div class="flex-fill">
                                    <div class="h6 mb-1">@s.Name</div>
                                    <div class="text-muted small">@s.MemberCount member(s) • @s.PostCount post(s)</div>
                                </div>
                            </div>

                            <div class="mt-auto d-grid">
                                <NavLink class="btn btn-primary btn-sm" href="@($"/Events/Create/{s.Id}")">Create event for this society</NavLink>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</div>

@code {
    List<SocietyDto> UserSocieties = new();
    bool isLoading = false;
    string? errorMessage;
    int CurrentUserId = 1;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var id = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? user.FindFirst("sub")?.Value;
                if (int.TryParse(id, out var parsed)) CurrentUserId = parsed;
            }

            UserSocieties = await SocietyService.GetUserSocietiesAsync(CurrentUserId);
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load your societies.";
        }
        finally
        {
            isLoading = false;
        }
    }

    string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }
}

<style>
    .society-card {
        transition: box-shadow .15s ease, transform .08s ease;
    }
    .society-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 22px rgba(0,0,0,0.08);
    }
    .society-initials {
        width:48px;
        height:48px;
        border-radius:50%;
        background:#0d6efd;
        color:#fff;
        display:flex;
        align-items:center;
        justify-content:center;
        font-weight:700;
        font-size:1rem;
    }
</style>