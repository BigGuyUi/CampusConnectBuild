@page "/Events"
@using System
@using System.Collections.Generic
@using System.Linq
@using System.Threading.Tasks
@using CampusConnect.Models
@using CampusConnect.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization

@inject IEventService EventService
@inject NavigationManager NavigationManager
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

<PageTitle>Events</PageTitle>

<div class="events-root">
    <header class="events-header">
        <div class="events-header-left">
            <h2 class="events-title">All Events</h2>
            <p class="events-sub">Upcoming campus events and society activities</p>
        </div>

        <div class="events-header-right">
            <div class="search-wrap">
                <input class="search-input" placeholder="Search events..." @bind="SearchQuery" />
            </div>
            <div class="actions">
                <NavLink class="btn btn-outline-primary" href="/Events/Create">Create Event</NavLink>
                <NavLink class="btn btn-outline-secondary" href="/Events/MyEvents">My Events</NavLink>
            </div>
        </div>
    </header>

    <section class="events-body">
        <div class="events-grid">
            @foreach (var evt in FilteredEvents)
            {
                <div class="mb-2">
                    <EventCard EventId="@evt.Id"
                               Slug="@evt.Slug"
                               Title="@evt.Title"
                               Date="@evt.DateDisplay"
                               SocietyName="@evt.SocietyName"
                               Tags="@evt.Tags"
                               Description="@evt.Text"
                               LikeCount="@evt.LikeCount"
                               ViewCount="@evt.ViewCount"
                               IsLiked="@evt.IsLiked"
                               IsViewed="@evt.IsViewed" />
                </div>
            }

            @if (!FilteredEvents.Any())
            {
                <div class="empty-state">
                    <h4>No events found</h4>
                    <p class="text-muted">Try adjusting your search or check back later.</p>
                </div>
            }
        </div>
    </section>
</div>

@code {
    string SearchQuery { get; set; } = "";
    List<EventDto> Eventss { get; set; } = new List<EventDto>();

    int? CurrentUserId = null;

    HashSet<int> UserSocietyIds { get; set; } = new();

    IEnumerable<EventDto> FilteredEvents
    {
        get
        {
            var q = Eventss.AsEnumerable();

            // Always show only events occurring today or in the future
            q = q.Where(e => e.EventDate.HasValue && e.EventDate.Value.Date >= DateTime.Today);

            if (!string.IsNullOrWhiteSpace(SearchQuery))
                q = q.Where(e =>
                    e.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    (e.SocietyName ?? "").Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    (e.Tags != null && e.Tags.Any(t => t.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))));

            return q;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated == true)
        {
            var idClaim = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)
                          ?? auth.User.FindFirst("sub");
            if (idClaim != null && int.TryParse(idClaim.Value, out var uid))
            {
                CurrentUserId = uid;
                UserSocietyIds = await EventService.GetUserSocietyIdsAsync(uid);
            }
        }
        await ReloadEvents();
    }

    async Task ReloadEvents()
    {
        // Request upcoming events from the server (today or later)
        Eventss = await EventService.GetFilteredEventsAsync(
            CurrentUserId,
            upcomingOnly: true,
            mySocietiesOnly: false);
        StateHasChanged();
    }
}
