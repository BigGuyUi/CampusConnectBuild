@page "/Events/MyEvents"
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using CampusConnect.Models
@using CampusConnect.Services
@inject IEventService EventService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>My Events</PageTitle>

<div class="container py-3">
    <header class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-0">My Events</h2>
            <div class="text-muted small">Events you RSVPd to and events you liked</div>
        </div>

        <div>
            <NavLink class="btn btn-outline-secondary btn-sm me-2" href="/Events">Back to Events</NavLink>
            <button class="btn btn-sm btn-outline-primary" @onclick="Refresh" disabled="@isLoading">Refresh</button>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="text-center py-4 text-muted">Loading…</div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else
    {
        <div class="row g-3">
            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <h5 class="mb-0">RSVP'd Events</h5>
                            <small class="text-muted">@Rsvpd.Count</small>
                        </div>

                        <div class="mini-grid overflow-auto">
                            @if (!Rsvpd.Any())
                            {
                                <div class="text-muted p-3">You have no RSVPs.</div>
                            }
                            else
                            {
                                <div class="row g-3">
                                    @foreach (var e in Rsvpd)
                                    {
                                        <div class="col-12 col-md-6">
                                            <MiniEventCard EventId="@e.Id"
                                                           Slug="@e.Slug"
                                                           Title="@e.Title"
                                                           Date="@e.DateDisplay"
                                                           SocietyName="@e.SocietyName"
                                                           Tags="@e.Tags"
                                                           Description="@e.Text"
                                                           LikeCount="@e.LikeCount"
                                                           ViewCount="@e.ViewCount"
                                                           IsRsvpd="true"
                                                           IsViewed="@e.IsViewed" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <h5 class="mb-0">Liked Events</h5>
                            <small class="text-muted">@Liked.Count</small>
                        </div>

                        <div class="mini-grid overflow-auto">
                            @if (!Liked.Any())
                            {
                                <div class="text-muted p-3">You have not liked any events.</div>
                            }
                            else
                            {
                                <div class="row g-3">
                                    @foreach (var e in Liked)
                                    {
                                        <div class="col-12 col-md-6">
                                            <MiniEventCard EventId="@e.Id"
                                                           Slug="@e.Slug"
                                                           Title="@e.Title"
                                                           Date="@e.DateDisplay"
                                                           SocietyName="@e.SocietyName"
                                                           Tags="@e.Tags"
                                                           Description="@e.Text"
                                                           LikeCount="@e.LikeCount"
                                                           ViewCount="@e.ViewCount"
                                                           IsLiked="true"
                                                           IsViewed="@e.IsViewed" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    List<EventDto> Rsvpd = new();
    List<EventDto> Liked = new();
    bool isLoading = false;
    string? errorMessage;
    int CurrentUserId = 1; // dev fallback; overridden when authenticated
    bool isActionRunning = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var idClaim = user.FindFirst(ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
                if (idClaim != null && int.TryParse(idClaim.Value, out var uid))
                    CurrentUserId = uid;
            }

            if (CurrentUserId > 0)
            {
                Rsvpd = await EventService.GetUserRsvpdEventsAsync(CurrentUserId);
                Liked = await EventService.GetUserLikedEventsAsync(CurrentUserId);

                // fetch per-event viewed flag in parallel
                var tasks = new List<Task>();
                foreach (var e in Rsvpd)
                {
                    tasks.Add(SetViewedFlagAsync(e));
                }
                foreach (var e in Liked)
                {
                    // avoid duplicate check if same event appears in both lists
                    if (!Rsvpd.Exists(x => x.Id == e.Id))
                        tasks.Add(SetViewedFlagAsync(e));
                    else
                        e.IsViewed = Rsvpd.Find(x => x.Id == e.Id).IsViewed;
                }
                await Task.WhenAll(tasks);
            }
            else
            {
                Rsvpd = new List<EventDto>();
                Liked = new List<EventDto>();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task SetViewedFlagAsync(EventDto e)
    {
        try
        {
            e.IsViewed = await EventService.IsEventViewedByUserAsync(e.Id, CurrentUserId);
        }
        catch
        {
            e.IsViewed = false;
        }
    }

    async Task Refresh()
    {
        await LoadAsync();
    }
}