@page "/Events/{slug}"
@rendermode InteractiveServer
@using CampusConnect.Models
@using CampusConnect.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components
@inject IEventService EventService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Event Details</PageTitle>

<div class="container py-4">
    @if (isLoading)
    {
        <div class="d-flex align-items-center gap-2">
            <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
            <div>Loading…</div>
        </div>
    }
    else if (loadError is not null)
    {
        <div class="alert alert-danger">
            <strong>Error:</strong> @loadError
        </div>

        <NavLink class="btn btn-secondary" href="/Events">Back to events</NavLink>
    }
    else if (evt is null)
    {
        <div class="text-center text-muted py-5">
            <h4>No event found</h4>
            <p class="mb-4">The event may have been removed or doesn't exist.</p>
            <NavLink class="btn btn-secondary" href="/Events">Back to events</NavLink>
        </div>
    }
    else
    {
        <div class="row gx-4">
            <div class="col-12">
                <NavLink class="btn btn-link p-0 mb-3" href="/Events">← Back to events</NavLink>
            </div>

            <div class="col-md-8">
                <article class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h1 class="h3 mb-1">@evt.Title</h1>

                        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                            @if (!string.IsNullOrWhiteSpace(evt.SocietyName))
                            {
                                <span class="badge bg-secondary text-uppercase small">@evt.SocietyName</span>
                            }

                            <small class="text-muted">@evt.DateDisplay</small>
                        </div>

                        <hr />

                        <div class="event-body" style="white-space:pre-wrap;">
                            @((MarkupString)evt.Text)
                        </div>
                    </div>
                </article>
            </div>

            <aside class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="h6 mb-3">Event Info</h5>

                        <dl class="row mb-3">
                            <dt class="col-4 text-muted small">When</dt>
                            <dd class="col-8 small mb-1">@((evt.EventDate ?? evt.PostTime).ToLocalTime().ToString("f"))</dd>

                            <dt class="col-4 text-muted small">Where</dt>
                            <dd class="col-8 small mb-1">@evt.Location</dd>

                            <dt class="col-4 text-muted small">Posted</dt>
                            <dd class="col-8 small mb-1">@evt.PostTime.ToLocalTime().ToString("g")</dd>

                            @if (evt.SocietyId is int sid)
                            {
                                <dt class="col-4 text-muted small">Society</dt>
                                <dd class="col-8 small mb-1">
                                    <a href="@($"/Societies/{sid}")" class="text-decoration-none">@evt.SocietyName</a>
                                </dd>
                            }
                        </dl>

                        <div class="mb-3">
                            <div class="d-flex gap-2">
                                @* Only disable while an action runs *@
                                <button class="btn btn-outline-secondary w-50" @onclick="OnLikeClicked" disabled="@isActionRunning">
                                    ❤️ Like (@evt.LikeCount)
                                </button>
                                <button class="btn btn-primary w-50" @onclick="OnRsvpClicked" disabled="@isActionRunning">
                                    ✅ RSVP (@evt.ReservationCount)
                                </button>
                            </div>
                        </div>

                        <div class="mt-auto d-flex gap-2">
                            <button class="btn btn-outline-secondary w-100" @onclick="Share">Share</button>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    }
</div>

@code {
    [Parameter]
    public string slug { get; set; } = "";

    EventDto? evt;
    bool isLoading = true;
    string? loadError;
    // DEV: default to user 1 for testing; will be overwritten when authenticated
    int CurrentUserId = 1;
    bool isActionRunning = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // determine user id if authenticated (overwrite the dev fallback)
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var idClaim = user.FindFirst(ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
                if (idClaim != null && int.TryParse(idClaim.Value, out var uid))
                {
                    CurrentUserId = uid;
                }
            }

            // load event by slug
            if (!string.IsNullOrWhiteSpace(slug))
            {
                evt = await EventService.GetEventBySlugAsync(slug);
            }

            if (evt is null)
            {
                loadError = "Event not found";
            }
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task OnRsvpClicked()
    {
        if (isActionRunning) return;

        isActionRunning = true;
        try
        {
            await EventService.RsvpEventAsync(evt!.Id, CurrentUserId);
            evt = await EventService.GetEventAsync(evt.Id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isActionRunning = false;
        }
    }

    async Task OnLikeClicked()
    {
        if (isActionRunning) return;

        isActionRunning = true;
        try
        {
            await EventService.LikeEventAsync(evt!.Id, CurrentUserId);
            evt = await EventService.GetEventAsync(evt.Id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isActionRunning = false;
        }
    }

    void Share()
    {
        try
        {
            var url = Nav.ToAbsoluteUri($"/Events/{slug}").ToString();
            Nav.NavigateTo(url, forceLoad: true);
        }
        catch
        {
        }
    }
}