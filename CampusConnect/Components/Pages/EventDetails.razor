@page "/Events/{slug}"
@rendermode InteractiveServer
@using CampusConnect.Models
@using CampusConnect.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components
@inject IEventService EventService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Event Details</PageTitle>

<style>
    .heart-btn {
        border: 0;
        background: transparent;
        font-size: 1.05rem;
        padding: 8px 12px;
        border-radius: 8px;
        transition: color .12s ease, background .12s ease;
        color: #6b7280;
    }
    .heart-btn:hover { background: rgba(0,0,0,0.04); }
    .heart-btn.liked { color: #e11d48; } /* pinkish-red */

    /* attendance dots inside details */
    .att-dots { display:inline-block; margin-right:8px; vertical-align:middle; }
    .att-dots .dot { width:12px; height:12px; border-radius:50%; background:#06b6d4; border:2px solid #fff; margin-left:-6px; box-shadow:0 6px 18px rgba(6,182,212,0.12); display:inline-block; }
    .att-legend { font-weight:700; color: rgba(15,23,42,0.85); margin-left:8px; }
</style>

<div class="container py-4">
    @if (isLoading)
    {
        <div class="d-flex align-items-center gap-2">
            <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
            <div>Loading…</div>
        </div>
    }
    else if (loadError is not null)
    {
        <div class="alert alert-danger">
            <strong>Error:</strong> @loadError
        </div>

        <NavLink class="btn btn-secondary" href="/Events">Back to events</NavLink>
    }
    else if (evt is null)
    {
        <div class="text-center text-muted py-5">
            <h4>No event found</h4>
            <p class="mb-4">The event may have been removed or doesn't exist.</p>
            <NavLink class="btn btn-secondary" href="/Events">Back to events</NavLink>
        </div>
    }
    else
    {
        <div class="row gx-4">
            <div class="col-12">
                <NavLink class="btn btn-link p-0 mb-3" href="/Events">← Back to events</NavLink>
            </div>

            <div class="col-md-8">
                <article class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h1 class="h3 mb-1">@evt.Title</h1>

                        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                            @if (!string.IsNullOrWhiteSpace(evt.SocietyName))
                            {
                                <span class="badge bg-secondary text-uppercase small">@evt.SocietyName</span>
                            }

                            <small class="text-muted">@evt.DateDisplay</small>
                        </div>

                        @if (evt.Tags is not null && evt.Tags.Any())
                        {
                            <div class="mb-3">
                                @foreach (var t in evt.Tags)
                                {
                                    <span class="badge bg-light text-dark me-1">@t.Name</span>
                                }
                            </div>
                        }

                        <hr />

                        <div class="event-body" style="white-space:pre-wrap;">
                            @((MarkupString)evt.Text)
                        </div>

                        @* Controls moved here: Like (heart only), RSVP (with count), Share *@
                        <div class="mt-3">
                            <div class="d-flex align-items-center gap-2">
                                <button class="heart-btn @(isLiked ? "liked" : "")" @onclick="OnLikeClicked" disabled="@isActionRunning" aria-pressed="@isLiked" aria-label="Like">
                                    @(isLiked ? "❤️" : "🤍")
                                </button>

                                <button class="btn btn-primary" @onclick="OnRsvpClicked" disabled="@isActionRunning" aria-label="RSVP">
                                    ✅ RSVP (@evt.ReservationCount)
                                </button>

                                <button class="btn btn-outline-secondary ms-2" @onclick="Share" aria-label="Share">
                                    Share
                                </button>
                            </div>
                        </div>
                    </div>
                </article>
            </div>

            <aside class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="h6 mb-3">Event Info</h5>

                        <dl class="row mb-3">
                            <dt class="col-4 text-muted small">When</dt>
                            <dd class="col-8 small mb-1">@((evt.EventDate ?? evt.PostTime).ToLocalTime().ToString("f"))</dd>

                            <dt class="col-4 text-muted small">Where</dt>
                            <dd class="col-8 small mb-1">@evt.Location</dd>

                            <dt class="col-4 text-muted small">Posted</dt>
                            <dd class="col-8 small mb-1">@evt.PostTime.ToLocalTime().ToString("g")</dd>

                            @if (evt.SocietyId is int sid)
                            {
                                <dt class="col-4 text-muted small">Society</dt>
                                <dd class="col-8 small mb-1">
                                    <a href="@($"/Societies/{sid}")" class="text-decoration-none">@evt.SocietyName</a>
                                </dd>
                            }

                            @* Attending row moved under Event Info *@
                            <dt class="col-4 text-muted small">Attending</dt>
                            <dd class="col-8 small mb-1">
                                <span class="att-dots" aria-hidden="true">
                                    @for (int i = 0; i < Math.Min(5, evt.ReservationCount); i++)
                                    {
                                        <span class="dot"></span>
                                    }
                                </span>
                                <span class="att-legend">@evt.ReservationCount attending</span>
                            </dd>
                        </dl>

                        <div class="mt-auto"></div>
                    </div>
                </div>
            </aside>
        </div>
    }
</div>

@code {
    [Parameter]
    public string slug { get; set; } = "";

    EventDto? evt;
    bool isLoading = true;
    string? loadError;
    int CurrentUserId = 1;
    bool isActionRunning = false;
    bool isLiked = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
                if (idClaim != null && int.TryParse(idClaim.Value, out var uid))
                {
                    CurrentUserId = uid;
                }
            }

            if (!string.IsNullOrWhiteSpace(slug))
            {
                evt = await EventService.GetEventBySlugAsync(slug);
            }

            if (evt is null)
            {
                loadError = "Event not found";
            }
            else
            {
                // record view for authenticated users (only counts first view per user)
                if (CurrentUserId > 0)
                {
                    try
                    {
                        await EventService.RecordViewAsync(evt.Id, CurrentUserId);
                    }
                    catch
                    {
                        // ignore view recording errors
                    }

                    // refresh counts and viewed state
                    evt = await EventService.GetEventAsync(evt.Id);

                    // get like state for this user
                    isLiked = await EventService.IsEventLikedByUserAsync(evt.Id, CurrentUserId);
                }
            }
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task OnRsvpClicked()
    {
        if (isActionRunning) return;
        isActionRunning = true;
        try
        {
            await EventService.RsvpEventAsync(evt!.Id, CurrentUserId);
            evt = await EventService.GetEventAsync(evt.Id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isActionRunning = false;
        }
    }

    async Task OnLikeClicked()
    {
        if (isActionRunning) return;
        isActionRunning = true;
        try
        {
            isLiked = await EventService.LikeEventAsync(evt!.Id, CurrentUserId);
            evt = await EventService.GetEventAsync(evt.Id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isActionRunning = false;
        }
    }

    void Share()
    {
        try
        {
            var url = Nav.ToAbsoluteUri($"/Events/{slug}").ToString();
            Nav.NavigateTo(url, forceLoad: true);
        }
        catch
        {
        }
    }
}