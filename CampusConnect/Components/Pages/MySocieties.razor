@page "/MySocieties"
@rendermode InteractiveServer
@using System
@using System.Linq
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using CampusConnect.Models
@using CampusConnect.Services
@inject ISocietyService SocietyService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>My Societies</PageTitle>

<div class="container py-3">
    <header class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-0">My Societies</h2>
            <div class="text-muted small">@UserSocieties.Count() society(ies)</div>
        </div>

        <div>
            <NavLink class="btn btn-outline-secondary btn-sm me-2" href="/Societies">Back to All</NavLink>
            <button class="btn btn-sm btn-outline-primary" @onclick="Refresh" disabled="@isLoading">Refresh</button>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="text-center py-5 text-muted">Loading…</div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else
    {
        @if (!UserSocieties.Any())
        {
            <div class="alert alert-info">You are not a member of any societies.</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var s in UserSocieties)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-start">
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3" style="width:48px;height:48px;font-weight:600;">
                                        @GetInitials(s.Name)
                                    </div>
                                    <div class="flex-fill">
                                        <div class="h6 mb-1">@s.Name</div>
                                        <div class="text-muted small">@s.MemberCount member(s) • @s.PostCount post(s)</div>
                                    </div>
                                </div>

                                <div class="mt-3 ms-auto">
                                    <div class="d-flex gap-2">
                                        <NavLink class="btn btn-sm btn-outline-secondary" href="@($"/Societies/{s.Id}")">Open</NavLink>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                @onclick="@(() => LeaveSocietyAsync(s.Id))"
                                                disabled="@LeavingSocietyIds.Contains(s.Id)">
                                            @if (LeavingSocietyIds.Contains(s.Id))
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                            }
                                            Leave
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    List<SocietyDto> UserSocieties = new();
    bool isLoading = false;
    string? errorMessage;
    int CurrentUserId = 1;

    // Track leaving actions so we can disable the appropriate button and show a spinner.
    HashSet<int> LeavingSocietyIds { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    async Task Refresh()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var idClaim = user.FindFirst(ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
                if (idClaim != null && int.TryParse(idClaim.Value, out var uid))
                {
                    CurrentUserId = uid;
                }
            }

            if (CurrentUserId > 0)
                UserSocieties = await SocietyService.GetUserSocietiesAsync(CurrentUserId);
            else
                UserSocieties = new List<SocietyDto>();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    async Task LeaveSocietyAsync(int societyId)
    {
        try
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to leave this society?");
            if (!confirmed) return;

            LeavingSocietyIds.Add(societyId);
            StateHasChanged();

            var removed = await SocietyService.LeaveSocietyAsync(CurrentUserId, societyId);

            if (removed)
            {
                // Optimistically remove from UI
                UserSocieties.RemoveAll(x => x.Id == societyId);
                errorMessage = null;
            }
            else
            {
                errorMessage = "Could not leave that society (possibly not a member).";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            LeavingSocietyIds.Remove(societyId);
            StateHasChanged();
        }
    }

    string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }
}