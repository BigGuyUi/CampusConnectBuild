@page "/Societies"
@rendermode InteractiveServer

@using System
@using System.Linq
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using CampusConnect.Models
@using CampusConnect.Services
@inject ISocietyService SocietyService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Societies</PageTitle>

<div class="societies-root container py-3">
    <header class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-0">All Societies</h2>
            <div class="text-muted small">@AllSocieties.Count() total • @UserSocieties.Count() joined</div>
        </div>

        <div class="d-flex align-items-center" style="gap:.5rem;">
            <input class="form-control form-control-sm" placeholder="Search societies..."
                   style="min-width:260px;"
                   @bind="SearchTerm" @bind:event="oninput" />

            <NavLink class="btn btn-outline-primary btn-sm" href="/MySocieties">My Societies</NavLink>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="text-center py-5 text-muted">Loading societies…</div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else
    {
        <section class="available-societies">
            @if (!FilteredAvailable.Any())
            {
                <div class="alert alert-info">No societies match your search or you're already a member of all societies.</div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var s in FilteredAvailable)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="society-card shadow-sm">
                                <div class="society-card-hero" style="@GetHeroStyle(s.Id)">
                                    @* Placeholder for a future prominent image. For now show initials *@
                                    <div class="hero-initials">@GetInitials(s.Name)</div>
                                </div>

                                <div class="society-card-body d-flex flex-column">
                                    <div>
                                        <div class="society-name h5 mb-1">@s.Name</div>
                                        <div class="text-muted small">@s.MemberCount member(s) • @s.PostCount post(s)</div>
                                    </div>

                                    <div class="mt-auto">
                                        @if (JoiningSocietyId == s.Id)
                                        {
                                            <div class="d-flex align-items-center">
                                                <input id="join-input-@s.Id"
                                                       class="form-control form-control-sm me-2"
                                                       style="width:160px;"
                                                       placeholder="Optional note..."
                                                       @bind="JoinText"
                                                       @bind:event="oninput"
                                                       @onkeydown="@(async (KeyboardEventArgs e) => await HandleJoinKeyDown(e, s.Id))"
                                                       @ref="joinInputRef" />

                                                <button class="btn btn-sm btn-primary me-1" @onclick="@(async () => await ConfirmJoinAsync(s.Id))" disabled="@isLoading">Confirm</button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelJoin" disabled="@isLoading">Cancel</button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex gap-2">
                                                <NavLink class="btn btn-sm btn-outline-secondary" href="@($"/Societies/{s.Id}")">View</NavLink>
                                                <button class="btn btn-sm btn-primary" @onclick="@(async () => await StartJoin(s.Id))">Join</button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    }
</div>

@code {
    List<SocietyDto> AllSocieties = new();
    List<SocietyDto> UserSocieties = new();
    IEnumerable<SocietyDto> Available => AllSocieties.Where(a => UserSocieties.All(u => u.Id != a.Id));
    IEnumerable<SocietyDto> FilteredAvailable => string.IsNullOrWhiteSpace(SearchTerm)
        ? Available
        : Available.Where(a => a.Name.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));

    bool isLoading = false;
    string? errorMessage;
    string SearchTerm = "";

    // Default to user id 1 for development/testing. Authenticated user will overwrite this.
    int CurrentUserId = 1;

    // join UI state
    int? JoiningSocietyId = null;
    string JoinText = "";
    ElementReference joinInputRef;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var idClaim = user.FindFirst(ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
                if (idClaim != null && int.TryParse(idClaim.Value, out var uid))
                {
                    CurrentUserId = uid;
                }
            }

            await LoadListsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task LoadListsAsync()
    {
        AllSocieties = await SocietyService.GetAllSocietiesAsync();
        if (CurrentUserId > 0)
            UserSocieties = await SocietyService.GetUserSocietiesAsync(CurrentUserId);
        else
            UserSocieties = new List<SocietyDto>();
    }

    string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }

    // New: hero background gradient; reserved for future image overlay
    string GetHeroStyle(int societyId)
    {
        var colors = new[] {
            "linear-gradient(180deg,#ef4444 0%,#fb923c 100%)",
            "linear-gradient(180deg,#8b5cf6 0%,#06b6d4 100%)",
            "linear-gradient(180deg,#06b6d4 0%,#10b981 100%)",
            "linear-gradient(180deg,#f59e0b 0%,#ef4444 100%)",
            "linear-gradient(180deg,#ef3b8b 0%,#7c3aed 100%)"
        };
        var idx = societyId > 0 ? Math.Abs(societyId.GetHashCode()) % colors.Length : 0;
        return $"background:{colors[idx]};display:flex;align-items:center;justify-content:center;";
    }

    async Task StartJoin(int id)
    {
        JoiningSocietyId = id;
        JoinText = "";
        StateHasChanged();

        // give Blazor a tick to render the input, then focus via same JS helper Chats uses
        await Task.Delay(50);
        await FocusJoinInputAsync();
    }

    void CancelJoin()
    {
        JoiningSocietyId = null;
        JoinText = "";
    }

    async Task ConfirmJoinAsync(int id)
    {
        if (CurrentUserId <= 0)
        {
            NavigationManager.NavigateTo("/"); // adjust to your login route if you have one
            return;
        }

        try
        {
            isLoading = true;
            await SocietyService.JoinSocietyAsync(CurrentUserId, id);
            await LoadListsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            CancelJoin();
        }
    }

    async Task HandleJoinKeyDown(KeyboardEventArgs e, int societyId)
    {
        if (e.Key == "Enter")
        {
            await ConfirmJoinAsync(societyId);
        }
    }

    async Task FocusJoinInputAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("chatHelpers.focusElement", joinInputRef);
        }
        catch
        {
            // ignore if helper missing; autofocus fallback may work
        }
    }
}
